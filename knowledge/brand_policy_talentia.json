{
  "schema_version": "1.0",
  "company": {
    "name": "Talentia",
    "source_document": "Talentia_Graphical_Charter_EN_20230131.pdf",
    "notes": "Draft extracted from graphical charter; should be reviewed by a human before production use."
  },
  "branding": {
    "logos": {
      "primary": {
        "description": "Main Talentia logo",
        "allowed_variants": [
          "standard",
          "white_on_identity_blue",
          "white_on_identity_pink",
          "black",
          "grey"
        ],
        "min_width_mm": 33,
        "protection_area_rule": "1X",
        "background_rules": {
          "preferred": ["white"],
          "allowed_identity_backgrounds": ["#24135F", "#D0006F"],
          "avoid_unreadable_backgrounds": true
        }
      },
      "responsive": {
        "description": "Responsive logo for smaller digital sizes",
        "min_width_mm": 14,
        "min_width_px": 40,
        "protection_area_mm": 20,
        "protection_area_px": 57
      },
      "icon": {
        "description": "Icon/favicons for very small digital usage",
        "sizes_px": [128, 96, 64, 48, 32, 16]
      }
    },
    "forbidden_logo_actions": [
      "create_monochrome_blue_version",
      "create_monochrome_pink_version",
      "apply_outline",
      "change_logotype_color",
      "rotate_logo",
      "add_shadow_or_other_effect",
      "place_on_non_identity_background",
      "place_on_unreadable_background",
      "violate_protection_area",
      "distort_logo"
    ]
  },
  "typography": {
    "brand_identity": {
      "primary_font_family": "Campton",
      "allowed_weights": [
        "Thin",
        "Extra Light",
        "Light",
        "Book",
        "Medium",
        "Semibold"
      ],
      "usage": "Brand identity and graphic design applications"
    },
    "office_documents": {
      "primary_font_family": "Arial",
      "secondary_font_family": "Arial Unicode MS",
      "allowed_weights": [
        "Regular",
        "Italic",
        "Bold"
      ],
      "usage": "Office documents and presentation workflows"
    },
    "presentation_default": {
      "title_font_family": "Arial",
      "body_font_family": "Arial",
      "fallback_font_family": "Arial Unicode MS"
    }
  },
  "colors": {
    "primary": [
      {
        "name": "Talentia Blue",
        "hex": "#24135F",
        "rgb": [36, 19, 95]
      },
      {
        "name": "Talentia Pink",
        "hex": "#D0006F",
        "rgb": [208, 0, 111]
      },
      {
        "name": "Cool Grey 5",
        "hex": "#B1B3B3",
        "rgb": [177, 179, 179]
      }
    ],
    "secondary": [
      {
        "name": "Violet",
        "hex": "#422990",
        "rgb": [66, 41, 144]
      },
      {
        "name": "Turquoise",
        "hex": "#2DCCD3",
        "rgb": [45, 204, 211]
      }
    ]
  },
  "document_variants": {
    "general": {
      "allowed_colors": ["#24135F", "#D0006F", "#422990", "#B1B3B3"]
    },
    "hr": {
      "allowed_colors": ["#24135F", "#D0006F", "#422990", "#B1B3B3"],
      "reserved_accent": "#D0006F"
    },
    "finance": {
      "allowed_colors": ["#24135F", "#D0006F", "#422990", "#2DCCD3", "#B1B3B3"],
      "reserved_accent": "#2DCCD3"
    }
  },
  "presentation_rules": {
    "require_logo_on_title_slide": true,
    "prefer_logo_on_all_slides": false,
    "require_template": true,
    "max_bullets_per_slide": 5,
    "max_words_per_bullet": 12,
    "max_title_characters": 55,
    "preferred_slide_types": [
      "title",
      "section",
      "bullet",
      "two_column"
    ],
    "avoid_image_slide_without_valid_asset": true
  },
  "layout_defaults": {
    "title_font_size_pt": 28,
    "body_font_size_pt": 18,
    "subtitle_font_size_pt": 20,
    "caption_font_size_pt": 12,
    "logo_position": "top_right",
    "footer_required": false
  },
  "assets": {
    "logo_primary_file": "assets/logo_primary.png",
    "logo_white_file": "assets/logo_white.png",
    "logo_responsive_file": "assets/logo_responsive.png",
    "logo_icon_file": "assets/logo_icon.png",
    "template_file": "templates/talentia_template.pptx"
  },
  "validation": {
    "check_logo_presence": true,
    "check_logo_variant": true,
    "check_font_family": true,
    "check_font_size_range": true,
    "check_color_palette": true,
    "check_bullet_density": true,
    "check_forbidden_logo_modifications": true
  }
}